{
  "name": "auditx",
  "version": "0.1.48",
  "description": "One command. Every vulnerability, dead code, and AI-generated code anti-pattern. JSON output built for AI coding agents to parse and self-fix.",
  "type": "module",
  "bin": {
    "auditx": "dist/auditx.js",
    "auditx-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsup src/bin/auditx.ts src/bin/mcp-server.ts --format esm --dts --outDir dist --clean",
    "dev": "tsx src/bin/auditx.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "audit",
    "claude",
    "cli",
    "security-audit",
    "sast",
    "semgrep",
    "trivy",
    "gitleaks",
    "vulnerability",
    "vulnerability-scanner",
    "ai-agent-tool",
    "claude-code",
    "cursor",
    "mcp",
    "code-quality",
    "ci-cd",
    "llm-safety",
    "ai-code-review"
  ],
  "author": "Parth",
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@google/genai": "^2.10.0",
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.17",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "openai": "^6.45.0",
    "ora": "^8.0.1",
    "tar": "^7.5.17"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.14.0",
    "tsup": "^8.5.1",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "src/rules"
  ],
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
