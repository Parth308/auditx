{
  "name": "auditx",
  "version": "0.1.11",
  "description": "One command. Every vulnerability. AI-ready markdown report.",
  "type": "module",
  "bin": "dist/auditx.js",
  "scripts": {
    "build": "tsup src/bin/auditx.ts --format esm --dts --outDir dist --clean --define.__VERSION__=\\\"0.1.11\\\"",
    "dev": "tsx src/bin/auditx.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "security",
    "audit",
    "cli",
    "semgrep",
    "trivy",
    "gitleaks",
    "vulnerability",
    "sast"
  ],
  "author": "Parth",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@google/genai": "^2.10.0",
    "@inquirer/prompts": "^8.5.2",
    "adm-zip": "^0.5.17",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "is-odd": "^3.0.1",
    "openai": "^6.45.0",
    "ora": "^8.0.1",
    "tar": "^7.5.17"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.14.0",
    "@types/tar": "^6.1.13",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "src/rules"
  ]
}
